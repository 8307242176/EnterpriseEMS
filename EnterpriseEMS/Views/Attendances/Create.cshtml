@model EnterpriseEMS.Models.Attendance.Attendance

@{
    ViewData["Title"] = "Create Attendance";
}

<div class="container-fluid px-3 px-lg-4 py-4">

    <div class="page-heading">

        <div class="page-heading-copy">

            <span class="page-icon">

                <i class="bi bi-calendar-plus"></i>

            </span>

            <div>

                <p class="eyebrow mb-1">

                    Attendance Management

                </p>

                <h1 class="h3 mb-1">

                    Add Attendance

                </h1>

                <p class="text-muted mb-0">

                    Create employee attendance record

                </p>

            </div>

        </div>


        <div class="heading-actions">

            <a asp-action="Index"
               class="btn btn-outline-secondary">

                Back

            </a>

        </div>

    </div>



    <section class="row g-3">

        <div class="col-xl-8">

            <form asp-action="Create"
                  method="post"
                  class="panel">


                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>



                <div class="panel-header">

                    <h2 class="h5">

                        Attendance Information

                    </h2>

                </div>



                <div class="row g-3">


                    <div class="col-md-6">

                        <label asp-for="EmployeeId"
                               class="form-label">

                            Employee

                        </label>


                        <select asp-for="EmployeeId"
                                asp-items="ViewBag.EmployeeId"
                                class="form-select">
                        </select>


                        <span asp-validation-for="EmployeeId"
                              class="text-danger"></span>

                    </div>




                    <div class="col-md-6">

                        <label asp-for="Date"
                               class="form-label"></label>

                        <input asp-for="Date"
                               class="form-control" />

                        <span asp-validation-for="Date"
                              class="text-danger"></span>

                    </div>




                    <div class="col-md-6">

                        <label asp-for="CheckInTime"
                               class="form-label"></label>

                        <input asp-for="CheckInTime"
                               class="form-control" />

                        <span asp-validation-for="CheckInTime"
                              class="text-danger"></span>

                    </div>




                    <div class="col-md-6">

                        <label asp-for="CheckOutTime"
                               class="form-label"></label>

                        <input asp-for="CheckOutTime"
                               class="form-control" />

                        <span asp-validation-for="CheckOutTime"
                              class="text-danger"></span>

                    </div>




                    <div class="col-md-6">

                        <label asp-for="Status"
                               class="form-label">

                            Status

                        </label>


                        <select asp-for="Status"
                                class="form-select">

                            <option value="">

                                Choose Status

                            </option>

                            <option>

                                Present

                            </option>

                            <option>

                                Absent

                            </option>

                            <option>

                                Leave

                            </option>

                            <option>

                                Half Day

                            </option>

                        </select>


                        <span asp-validation-for="Status"
                              class="text-danger"></span>

                    </div>



                </div>



                <div class="d-flex justify-content-end gap-2 mt-4">


                    <a asp-action="Index"
                       class="btn btn-outline-secondary">

                        Cancel

                    </a>


                    <button type="submit"
                            class="btn btn-primary">

                        Create Attendance

                    </button>


                </div>



            </form>

        </div>



        <div class="col-xl-4">

            <div class="panel h-100">

                <h5>

                    Attendance Rules

                </h5>


                <div class="activity-list">


                    <div class="activity-item">

                        <div>

                            <p class="fw-semibold">

                                Check In

                            </p>

                            <p class="small text-muted">

                                Employee must clock in

                            </p>

                        </div>

                    </div>



                    <div class="activity-item">

                        <div>

                            <p class="fw-semibold">

                                Check Out

                            </p>

                            <p class="small text-muted">

                                Required before day closes

                            </p>

                        </div>

                    </div>



                    <div class="activity-item">

                        <div>

                            <p class="fw-semibold">

                                Status

                            </p>

                            <p class="small text-muted">

                                Choose proper attendance type

                            </p>

                        </div>

                    </div>


                </div>


            </div>

        </div>


    </section>

</div>


@section Scripts {

    @{

        await Html.RenderPartialAsync(
        "_ValidationScriptsPartial");

    }

}