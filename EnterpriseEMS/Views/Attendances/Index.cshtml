@model IEnumerable<EnterpriseEMS.Models.Attendance.Attendance>

@{
    ViewData["Title"] = "Attendance";
}

<div class="container-fluid px-3 px-lg-4 py-4">

    <div class="page-heading">

        <div class="page-heading-copy">

            <span class="page-icon">

                <i class="bi bi-calendar-check"></i>

            </span>

            <div>

                <p class="eyebrow mb-1">

                    Attendance Management

                </p>

                <h1 class="h3 mb-1">

                    Attendance Records

                </h1>

                <p class="text-muted mb-0">

                    Track employee attendance records

                </p>

            </div>

        </div>


        <div class="heading-actions">

            <a asp-action="Create"
               class="btn btn-primary">

                <i class="bi bi-plus-circle"></i>

                Add Attendance

            </a>

        </div>

    </div>



    <section class="row g-3 mb-4">


        <div class="col-md-4">

            <div class="panel">

                <p class="text-muted">

                    Total Records

                </p>

                <h3>

                    @Model.Count()

                </h3>

            </div>

        </div>



        <div class="col-md-4">

            <div class="panel">

                <p class="text-muted">

                    Present

                </p>

                <h3>

                    @Model.Count(x => x.Status == "Present")

                </h3>

            </div>

        </div>



        <div class="col-md-4">

            <div class="panel">

                <p class="text-muted">

                    Absent

                </p>

                <h3>

                    @Model.Count(x => x.Status == "Absent")

                </h3>

            </div>

        </div>


    </section>



    <div class="panel">

        <div class="table-responsive">

            <table class="table align-middle">

                <thead>

                    <tr>

                        <th>

                            Employee

                        </th>

                        <th>

                            Date

                        </th>

                        <th>

                            Check In

                        </th>

                        <th>

                            Check Out

                        </th>

                        <th>

                            Status

                        </th>

                        <th class="text-end">

                            Actions

                        </th>

                    </tr>

                </thead>


                <tbody>


                    @foreach (var item in Model)
                    {

                        <tr>


                            <td>

                                <div>

                                    <p class="fw-semibold mb-0">

                                        @item.Employee.FullName

                                    </p>

                                    <small class="text-muted">

                                        @item.Employee.Email

                                    </small>

                                </div>

                            </td>



                            <td>

                                @item.Date.ToShortDateString()

                            </td>



                            <td>

                                @item.CheckInTime

                            </td>



                            <td>

                                @item.CheckOutTime

                            </td>



                            <td>

                                @if (item.Status == "Present")
                                {
                                    <span class="badge text-bg-success">

                                        Present

                                    </span>
                                }
                                else
                                {
                                    <span class="badge text-bg-danger">

                                        Absent

                                    </span>
                                }

                            </td>



                            <td class="text-end">


                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">

                                    View

                                </a>


                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">

                                    Edit

                                </a>


                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">

                                    Delete

                                </a>


                            </td>


                        </tr>

                    }


                </tbody>

            </table>

        </div>

    </div>

</div>