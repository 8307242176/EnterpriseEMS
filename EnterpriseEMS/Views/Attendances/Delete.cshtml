@model EnterpriseEMS.Models.Attendance.Attendance

@{
    ViewData["Title"] = "Delete Attendance";
}

<div class="container-fluid px-3 px-lg-4 py-4">

    <div class="page-heading">

        <h1 class="h3">

            Delete Attendance

        </h1>

        <p class="text-muted">

            Confirm attendance deletion

        </p>

    </div>



    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="panel">

                <div class="text-center mb-4">

                    <i class="bi bi-exclamation-triangle-fill text-danger"
                       style="font-size:70px;"></i>

                    <h3 class="mt-3">

                        Delete Record?

                    </h3>

                    <p class="text-muted">

                        This attendance entry will be removed permanently.

                    </p>

                </div>



                <div class="row g-3">


                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>

                                Employee

                            </span>

                            <strong>

                                @Model.Employee.FullName

                            </strong>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>

                                Date

                            </span>

                            <strong>

                                @Model.Date.ToShortDateString()

                            </strong>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>

                                Check In

                            </span>

                            <strong>

                                @Model.CheckInTime

                            </strong>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>

                                Status

                            </span>

                            <strong>

                                @Model.Status

                            </strong>

                        </div>

                    </div>


                </div>



                <form asp-action="Delete"
                      class="mt-5">

                    <input type="hidden"
                           asp-for="Id" />


                    <div class="d-flex justify-content-center gap-3">


                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            Cancel

                        </a>


                        <button type="submit"
                                class="btn btn-danger">

                            Delete Attendance

                        </button>


                    </div>


                </form>


            </div>

        </div>

    </div>

</div>