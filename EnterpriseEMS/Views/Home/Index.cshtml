@{
    ViewData["Title"] = "Enterprise EMS";
}

<section class="hero-section py-5">

    <div class="container-fluid px-4">


        <div class="row align-items-center min-vh-75">


            <div class="col-lg-6">


                <p class="eyebrow mb-2">

                    Enterprise Employee Management System

                </p>


                <h1 class="display-3 fw-bold mb-4">

                    Manage Employees,

                    Attendance & Leave

                    In One Platform

                </h1>


                <p class="lead text-muted mb-4">

                    A centralized solution for managing employees,
                    attendance tracking, leave requests,
                    and workforce operations efficiently.

                </p>



                <div class="d-flex gap-3 flex-wrap">


                    @if (User.Identity.IsAuthenticated)
                    {

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-primary btn-lg">

                            Go To Dashboard

                        </a>

                    }
                    else
                    {

                        <a asp-area="Identity"
                           asp-page="/Account/Login"
                           class="btn btn-primary btn-lg">

                            Login

                        </a>

                    }


                    <a href="#features"
                       class="btn btn-outline-secondary btn-lg">

                        Learn More

                    </a>


                </div>


            </div>




            <div class="col-lg-6 text-center">


                <img src="~/images/png/dasher-ui-bootstrap-5.jpg"
                     class="img-fluid rounded shadow"
                     style="max-height:500px;">


            </div>


        </div>


    </div>

</section>




<section id="features"
         class="py-5">

    <div class="container-fluid px-4">


        <div class="text-center mb-5">


            <h2 class="fw-bold">

                Platform Features

            </h2>


            <p class="text-muted">

                Everything required for workforce management

            </p>


        </div>




        <div class="row g-4">


            <div class="col-md-4">

                <div class="panel h-100 text-center p-4">


                    <i class="bi bi-people"
                       style="font-size:55px;"></i>


                    <h4 class="mt-3">

                        Employee Management

                    </h4>


                    <p class="text-muted">

                        Create, update and manage employee records easily.

                    </p>


                </div>

            </div>




            <div class="col-md-4">

                <div class="panel h-100 text-center p-4">


                    <i class="bi bi-calendar-check"
                       style="font-size:55px;"></i>


                    <h4 class="mt-3">

                        Attendance Tracking

                    </h4>


                    <p class="text-muted">

                        Monitor employee attendance and work schedules.

                    </p>


                </div>

            </div>




            <div class="col-md-4">

                <div class="panel h-100 text-center p-4">


                    <i class="bi bi-calendar-event"
                       style="font-size:55px;"></i>


                    <h4 class="mt-3">

                        Leave Management

                    </h4>


                    <p class="text-muted">

                        Approve, reject and track leave requests efficiently.

                    </p>


                </div>

            </div>


        </div>


    </div>

</section>




<section class="py-5">

    <div class="container-fluid px-4">

        <div class="panel p-5 text-center">


            <h2 class="mb-3">

                Ready To Simplify Workforce Management?

            </h2>


            <p class="text-muted mb-4">

                Secure, scalable and built for modern organizations.

            </p>


            @if (!User.Identity.IsAuthenticated)
            {

                <a asp-area="Identity"
                   asp-page="/Account/Login"
                   class="btn btn-primary btn-lg">

                    Get Started

                </a>

            }


        </div>

    </div>

</section>