@model EnterpriseEMS.Models.Leave.LeaveRequest

@{
    ViewData["Title"] = "Delete Leave";
}

<div class="container-fluid px-3 px-lg-4 py-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="panel">


                <div class="text-center mb-4">


                    <i class="bi bi-exclamation-triangle-fill text-danger"
                       style="font-size:70px;"></i>


                    <h3 class="mt-3">

                        Delete Leave Request?

                    </h3>


                    <p class="text-muted">

                        This action cannot be undone.

                    </p>


                </div>



                <div class="row g-3">


                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>

                                Employee

                            </span>

                            <strong>

                                @Model.EmployeeId

                            </strong>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>

                                Status

                            </span>

                            <strong>

                                @Model.Status

                            </strong>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>

                                From

                            </span>

                            <strong>

                                @Model.StartDate.ToShortDateString()

                            </strong>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>

                                To

                            </span>

                            <strong>

                                @Model.EndDate.ToShortDateString()

                            </strong>

                        </div>

                    </div>


                </div>



                <form asp-action="Delete"
                      class="mt-5">

                    <input type="hidden"
                           asp-for="Id" />


                    <div class="d-flex justify-content-center gap-3">


                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            Cancel

                        </a>


                        <button class="btn btn-danger"
                                type="submit">

                            Delete Leave

                        </button>


                    </div>


                </form>


            </div>

        </div>

    </div>

</div>