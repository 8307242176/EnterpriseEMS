@model EnterpriseEMS.Models.Leave.LeaveRequest

@{
    ViewData["Title"] = "Create Leave Request";
}

<div class="container-fluid px-3 px-lg-4 py-4">

    <div class="page-heading">

        <div class="page-heading-copy">

            <span class="page-icon">

                <i class="bi bi-calendar-plus"></i>

            </span>

            <div>

                <p class="eyebrow mb-1">

                    Leave Management

                </p>

                <h1 class="h3 mb-1">

                    Create Leave Request

                </h1>

                <p class="text-muted mb-0">

                    Submit a new leave application

                </p>

            </div>

        </div>


        <div class="heading-actions">

            <a asp-action="Index"
               class="btn btn-outline-secondary">

                Back

            </a>

        </div>

    </div>




    <section class="row g-3">


        <div class="col-xl-8">


            <form asp-action="Create"
                  method="post"
                  class="panel">


                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>



                <div class="panel-header">

                    <h2 class="h5">

                        Leave Information

                    </h2>

                </div>



                <div class="row g-3">


                    <div class="col-md-6">

                        <label class="form-label">

                            Employee Account

                        </label>

                        <input class="form-control"
                               value="@User.Identity?.Name"
                               readonly>

                        <input asp-for="EmployeeId"
                               type="hidden"
                               value="1" />

                    </div>




                    <div class="col-md-6">

                        <label asp-for="StartDate"
                               class="form-label">

                            Start Date

                        </label>


                        <input asp-for="StartDate"
                               class="form-control" />


                        <span asp-validation-for="StartDate"
                              class="text-danger"></span>

                    </div>




                    <div class="col-md-6">

                        <label asp-for="EndDate"
                               class="form-label">

                            End Date

                        </label>


                        <input asp-for="EndDate"
                               class="form-control" />


                        <span asp-validation-for="EndDate"
                              class="text-danger"></span>

                    </div>
                    <div class="col-md-6">

                        <label asp-for="LeaveType"
                               class="form-label">

                            Leave Type

                        </label>

                        <select asp-for="LeaveType"
                                class="form-select">

                            <option value="">

                                Choose Leave Type

                            </option>

                            <option>

                                Sick Leave

                            </option>

                            <option>

                                Casual Leave

                            </option>

                            <option>

                                Annual Leave

                            </option>

                            <option>

                                Emergency Leave

                            </option>

                        </select>

                        <span asp-validation-for="LeaveType"
                              class="text-danger">

                        </span>

                    </div>



                    <div class="col-12">

                        <label asp-for="Reason"
                               class="form-label">

                            Reason

                        </label>


<textarea asp-for="Reason"
          class="form-control"
          rows="5">

</textarea>


                        <span asp-validation-for="Reason"
                              class="text-danger"></span>

                    </div>




                    <div class="col-md-6">

                        <label class="form-label">

                            Status

                        </label>


                        <input class="form-control"
                               value="Pending"
                               readonly />


                        <small class="text-muted">

                           

                        </small>

                    </div>


                </div>




                <div class="d-flex justify-content-end gap-2 mt-4">


                    <a asp-action="Index"
                       class="btn btn-outline-secondary">

                        Cancel

                    </a>


                    <button class="btn btn-primary"
                            type="submit">

                        Submit Leave Request

                    </button>


                </div>


            </form>


        </div>




        <div class="col-xl-4">


            <div class="panel h-100">


                <h5>

                    Leave Guidelines

                </h5>


                <div class="activity-list">


                    <div class="activity-item">

                        <div>

                            <p class="fw-semibold">

                                Apply Early

                            </p>

                            <p class="small text-muted">

                                Submit before leave starts

                            </p>

                        </div>

                    </div>



                    <div class="activity-item">

                        <div>

                            <p class="fw-semibold">

                                Pending Approval

                            </p>

                            <p class="small text-muted">

                                HR/Admin approval required

                            </p>

                        </div>

                    </div>



                    <div class="activity-item">

                        <div>

                            <p class="fw-semibold">

                                Provide Reason

                            </p>

                            <p class="small text-muted">

                                Clear reason speeds approval

                            </p>

                        </div>

                    </div>


                </div>


            </div>


        </div>


    </section>

</div>


@section Scripts {

    @{

        await Html.RenderPartialAsync(
        "_ValidationScriptsPartial");

    }

}